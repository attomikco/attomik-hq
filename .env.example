# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend — transactional email (invoice sending)
# 1. Create an API key: https://resend.com/api-keys
# 2. Verify the attomik.co domain in Resend and add the DNS records to Cloudflare.
RESEND_API_KEY=
# The address invoices are sent from (must be on a verified domain).
INVOICE_FROM=Attomik Accounts <accounts@attomik.co>
# Optional: address for client replies (defaults to INVOICE_FROM).
INVOICE_REPLY_TO=
# Address CC'd on every invoice email (defaults to pablo@attomik.co).
INVOICE_CC=
