# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (SECRET, server-only — never NEXT_PUBLIC). Used by the
# auto-send cron to read/write invoices under RLS. Supabase dashboard →
# Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email (invoice sending)
# 1. Create an API key: https://resend.com/api-keys
# 2. Verify the attomik.co domain in Resend and add the DNS records to Cloudflare.
RESEND_API_KEY=
# The address invoices are sent from (must be on a verified domain).
INVOICE_FROM=Attomik Accounts <accounts@attomik.co>
# Optional: address for client replies (defaults to INVOICE_FROM).
INVOICE_REPLY_TO=
# Extra CC addresses for invoice emails (comma-separated). pablo@attomik.co is
# always CC'd regardless; this only ADDS more.
INVOICE_CC=
# The address the deal package (agreement + proposal + invoice) is sent from.
# Defaults to "Attomik <accounts@attomik.co>" with reply_to pablo@attomik.co.
# If overridden to a pablo@ address, accounts@ is CC'd instead.
PACKAGE_FROM=Attomik <accounts@attomik.co>

# Auto-send cron (sends "ready" invoices on their issue date, 9am ET daily).
# Secret Vercel Cron presents as a bearer token — required for the route to run.
CRON_SECRET=
# Master switch: leave unset/false for dry-run (digests only, no client emails);
# set to "true" to actually send.
INVOICE_CRON_LIVE=
# Where the run digest goes (defaults to pablo@attomik.co).
CRON_DIGEST_TO=
